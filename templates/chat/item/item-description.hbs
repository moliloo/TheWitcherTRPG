<section class="chat-item-description">
    <header class="chat-item-header">
        <img src="{{item.img}}" alt="">
        <h4>{{item.name}}</h4>
    </header>
    <div class="chat-description">
        {{> "systems/TheWitcherTRPG/templates/chat/item/partials/item-description/description.hbs" type=type description=item.system.description }}
        {{> "systems/TheWitcherTRPG/templates/chat/item/partials/item-description/spell.hbs" type=type effect=item.system.effect sideEffect=item.system.sideEffect liftRequirement=item.system.liftRequirement }}
        {{> "systems/TheWitcherTRPG/templates/chat/item/partials/item-description/alchemicals.hbs" type=type itemType=(../itemType) description=item.system.description effect=item.system.effect minorMutation=item.system.minorMutation location=item.system.location }}
    </div>
    <div class="chat-components">
        {{> "systems/TheWitcherTRPG/templates/chat/item/partials/item-description/crafting-items.hbs" type=type craftingComponents=item.system.craftingComponents isFormulae=item.system.isFormulae alchemyComponents=item.system.alchemyComponents}}
    </div>
    <footer class="chat-item-tags item-tags">
        {{> "systems/TheWitcherTRPG/templates/chat/item/partials/item-description/tags.hbs" type=type description=item.system.description }}
    </footer>
</section>